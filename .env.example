# Jarvis secrets — copy this file into your Jarvis data directory as `.env`:
#
#   cp .env.example ~/jarvis/.env        # or  $JARVIS_HOME/.env
#
# Jarvis loads `<data-dir>/.env` on startup (Node 22+ native, no dependency),
# so your secrets live next to your data (config.yaml, tasks.db) — outside this
# code repo. `.env` is gitignored; this `.env.example` is the committed
# template. Every value is optional; Jarvis also reads the process environment.
#
# Note: JARVIS_HOME is NOT read from here — it's the variable that locates this
# file. Export it (e.g. in your shell profile) if you want a non-default data
# directory; otherwise Jarvis uses ~/jarvis.

# ── Claude Agent SDK auth (Phase 2+ execution) ─────────────────────────────
# Option ②: API key for always-on / serverless runs. Leave blank when you run
# locally with a Claude subscription login (option ①) — same code, only the
# credential differs.
ANTHROPIC_API_KEY=

# ── Connector secrets (consumed once the live MCP wiring lands) ─────────────
# Jarvis passes these to the MCP servers it spawns. Each MCP server owns its
# own auth flow/storage beyond what is set here. Exact variable names may be
# adjusted to match the specific MCP server you wire up.

# GitHub connector — a (fine-grained) personal access token with read access
# to the repos/issues you track. Passed to the GitHub MCP server.
GITHUB_PERSONAL_ACCESS_TOKEN=

# Gmail + Google Calendar connectors — Google OAuth *client* credentials.
# The refresh token itself is obtained via a one-time browser consent flow and
# stored by the Google MCP server (not here).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
